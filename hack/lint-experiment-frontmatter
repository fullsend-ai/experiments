#!/usr/bin/env python3
# /// script
# requires-python = ">=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""Validate frontmatter in experiment files.

Checks:
- Experiment files have required frontmatter fields (title, status)
- Status is a valid value (Active, Concluded, Abandoned, Merged)
- topics is a list if present
- H1 heading matches frontmatter title exactly

Adapted from fullsend-ai/fullsend hack/lint-adr-frontmatter
"""

import os
import re
import sys

import yaml

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

VALID_STATUSES = {"Active", "Concluded", "Abandoned", "Merged"}


def parse_frontmatter(filepath):
    """Extract YAML frontmatter from a markdown file. Returns (dict, error)."""
    with open(filepath, encoding="utf-8") as f:
        content = f.read()

    if not content.startswith("---\n"):
        return None, "missing frontmatter"

    end = content.find("\n---\n", 4)
    if end == -1:
        end = content.find("\n---\r\n", 4)
    if end == -1:
        return None, "missing closing frontmatter delimiter"

    fm_text = content[4:end]
    try:
        data = yaml.safe_load(fm_text)
    except yaml.YAMLError as e:
        return None, f"invalid YAML: {e}"

    if not isinstance(data, dict):
        return None, "frontmatter is not a mapping"

    return data, None


def find_experiment_md(entry_path):
    """Find the markdown file for an experiment entry."""
    if os.path.isfile(entry_path) and entry_path.endswith(".md"):
        return entry_path
    for candidate in ["README.md", "EXPERIMENT.md"]:
        path = os.path.join(entry_path, candidate)
        if os.path.isfile(path):
            return path
    return None


def extract_h1(filepath):
    """Extract the first H1 heading from a markdown file."""
    with open(filepath, encoding="utf-8") as f:
        for line in f:
            m = re.match(r"^#\s+(.+)$", line.rstrip())
            if m:
                return m.group(1)
    return None


def validate_experiment(filepath):
    """Validate an experiment file's frontmatter. Returns list of error strings."""
    errors = []
    rel_path = os.path.relpath(filepath, REPO_ROOT)

    fm, err = parse_frontmatter(filepath)
    if err:
        return [f"{rel_path}: {err}"]

    for field in ["title", "status"]:
        if field not in fm:
            errors.append(f"{rel_path}: missing required field '{field}'")

    if "status" in fm:
        if fm["status"] not in VALID_STATUSES:
            errors.append(
                "{}: invalid status '{}'. Valid: {}".format(
                    rel_path, fm["status"], ", ".join(sorted(VALID_STATUSES))
                )
            )

    if "topics" in fm and not isinstance(fm["topics"], list):
        errors.append(
            "{}: topics must be a YAML list, got {}".format(
                rel_path, type(fm["topics"]).__name__
            )
        )

    if "title" in fm:
        h1 = extract_h1(filepath)
        if h1 is None:
            errors.append(f"{rel_path}: missing H1 heading")
        elif h1 != fm["title"]:
            errors.append(
                "{}: H1 heading does not match frontmatter title\n"
                "       title: {}\n"
                "       H1:    {}".format(rel_path, fm["title"], h1)
            )

    return errors


def main():
    print("INFO: Validating experiment frontmatter...")
    print()

    entries = []
    for name in sorted(os.listdir(REPO_ROOT)):
        if re.match(r"^\d{4}-", name) and not name.startswith("0000-"):
            full_path = os.path.join(REPO_ROOT, name)
            md_file = find_experiment_md(full_path)
            if md_file:
                entries.append(md_file)

    if not entries:
        print("WARNING: No experiment files found")
        return 0

    print(f"INFO: Found {len(entries)} experiment files to check")
    print("Checking experiment frontmatter...")
    print("=" * 50)

    all_errors = []
    for filepath in entries:
        rel = os.path.relpath(filepath, REPO_ROOT)
        file_errors = validate_experiment(filepath)
        if file_errors:
            all_errors.extend(file_errors)
            print(f"  {rel}: FAIL")
        else:
            print(f"  {rel}: OK")

    print("=" * 50)

    if all_errors:
        print(f"ERROR: {len(all_errors)} frontmatter validation error(s)")
        for e in all_errors:
            print(f"  ERROR: {e}")
        return 1
    else:
        print(f"OK: All {len(entries)} experiment files have valid frontmatter")
        return 0


if __name__ == "__main__":
    sys.exit(main())
